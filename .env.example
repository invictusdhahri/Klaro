# =============================================================================
# Klaro — environment variables
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# ---- Supabase (shared) ------------------------------------------------------
# From: supabase status (local) or your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
# Service-role key — apps/api ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# ---- Anthropic (Claude) -----------------------------------------------------
# Used by apps/api (chat) and apps/ml (LLM scorer)
ANTHROPIC_API_KEY=replace-with-anthropic-key

# ---- Service URLs -----------------------------------------------------------
# Web -> API
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000
# API -> ML sidecar
ML_BASE_URL=http://localhost:8000

# ---- API server -------------------------------------------------------------
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug
# Comma-separated allowlist for CORS
CORS_ORIGINS=http://localhost:3000

# ---- ML sidecar -------------------------------------------------------------
ML_PORT=8000
ML_ENV=development

# ---- Bank credential envelope (RSA-OAEP, base64-encoded PEM) ----------------
# Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:4096
# Public key is shipped to the browser to encrypt credentials client-side.
# Private key lives on apps/api ONLY.
CREDENTIAL_ENCRYPTION_PUBLIC_KEY=
CREDENTIAL_ENCRYPTION_PRIVATE_KEY=

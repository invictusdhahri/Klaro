{
  "name": "@klaro/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types/*": "./src/types/*.ts",
    "./schemas/*": "./src/schemas/*.ts",
    "./constants/*": "./src/constants/*.ts",
    "./api": "./src/api/index.ts",
    "./utils/*": "./src/utils/*.ts"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@klaro/eslint-config": "workspace:*",
    "@klaro/tsconfig": "workspace:*",
    "eslint": "^8.57.1",
    "typescript": "^5.6.3"
  }
}
